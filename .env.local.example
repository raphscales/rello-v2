# Supabase (create a new project named "rello-v2" at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ClickSend (NZ SMS)
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_WEBHOOK_SECRET=

# Twilio (missed call detection only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_USER_ID=

# Twilio webhook URL (full public URL, e.g. https://rello-v2.vercel.app/api/webhooks/twilio)
TWILIO_WEBHOOK_URL=
